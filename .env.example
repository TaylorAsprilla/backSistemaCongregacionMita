# ============================================
# CONFIGURACIÓN DE ENTORNO
# ============================================

# Entorno de ejecución (development, production, test)
NODE_ENV=development

# Puerto del servidor
PORT=4000

# ============================================
# BASE DE DATOS
# ============================================

# Configuración de base de datos para desarrollo
DB_USERNAME_DEV=congregacion_user
DB_PASSWORD_DEV=congregacion_pass_2024
DB_DATABASE_DEV=congregacion_mita_local
DB_HOST_DEV=localhost
DB_DIALECT=mysql

# Configuración de base de datos para producción
DB_USERNAME_PRO=tu_usuario_produccion
DB_PASSWORD_PRO=tu_password_produccion
DB_DATABASE_PRO=congregacion_mita_prod
DB_HOST_PRO=tu_host_produccion
DB_DIALECT_PRO=mysql

# Variables adicionales de base de datos
SIN_CONGREGACION=1
SIN_CAMPO=1

# ============================================
# SEGURIDAD Y AUTENTICACIÓN
# ============================================

# CRÍTICO: Secret para JWT - DEBE tener mínimo 32 caracteres
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# NUNCA uses valores de ejemplo en producción
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_AT_LEAST_64_CHARACTERS_LONG_IN_PRODUCTION

# Secret para reset de password
JWT_SECRET_RESET=your-super-secure-jwt-secret-reset-change-in-production

# ============================================
# NOTAS DE SEGURIDAD IMPORTANTES
# ============================================
# 
# ⚠️  ANTES DE DESPLEGAR A PRODUCCIÓN:
# 
# 1. JWT_SECRET: Generar un secreto único y fuerte (64+ caracteres)
# 2. JWT_SECRET_RESET: Diferente al JWT_SECRET principal
# 3. Contraseñas de Email: Usar App Passwords, NO la contraseña real de Gmail
# 4. Base de Datos: Credenciales diferentes para dev/qa/prod
# 5. NUNCA subir el archivo .env real al repositorio
# 6. Rotar secretos cada 3-6 meses en producción
# 
# El servidor ahora valida automáticamente todas las variables críticas
# al iniciar. Si falta alguna requerida, el servidor no arrancará.
#
# ============================================

# ============================================
# CONFIGURACIÓN DE EMAIL
# ============================================

# Email - Desarrollo
HOST_EMAIL_DEVELOPMENT=smtp.gmail.com
PORT_EMAIL_DEVELOPMENT=587
USER_EMAIL_DEVELOPMENT=your-email@gmail.com
PASS_EMAIL_DEVELOPMENT=your-app-password
FROM_EMAIL_DEVELOPMENT=your-email@gmail.com
SERVICE_EMAIL_DEVELOPMENT=gmail

# Email - Producción
HOST_EMAIL_PRODUCTION=smtp.gmail.com
PORT_EMAIL_PRODUCTION=587
USER_EMAIL_PRODUCTION=your-email@gmail.com
PASS_EMAIL_PRODUCTION=your-app-password
FROM_EMAIL_PRODUCTION=your-email@gmail.com
SERVICE_EMAIL_PRODUCTION=gmail

# ============================================
# URLS Y APIS EXTERNAS
# ============================================

# API para geolocalización de IP
IP_API=http://ip-api.com/json/

# URL para login por QR - Desarrollo
LOGIN_POR_QR_DEV=http://localhost:4200/#/login?ticket=

# URL para login por QR - Producción
LOGIN_POR_QR_PRO=https://tu-dominio-produccion.com/#/login?ticket=
